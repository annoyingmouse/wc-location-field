{
  "name": "@annoyingmouse/wc-location-field",
  "version": "1.0.0",
  "description": "A web component for location selection with address search, interactive map, geolocation, and What3Words support.",
  "main": "wc-location-field.js",
  "type": "module",
  "scripts": {
    "test": "web-test-runner",
    "test:dist": "web-test-runner --config web-test-runner.dist.config.mjs",
    "build": "rollup -c",
    "release": "npm run build && npm publish --access public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/annoyingmouse/wc-location-field.git"
  },
  "keywords": [
    "web-component",
    "custom-element",
    "location",
    "geocoding",
    "nominatim",
    "leaflet",
    "geolocation",
    "what3words",
    "accessibility",
    "a11y"
  ],
  "author": "Dominic Myers",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/annoyingmouse/wc-location-field/issues"
  },
  "homepage": "https://github.com/annoyingmouse/wc-location-field#readme",
  "prettier": {
    "singleQuote": true,
    "semi": false
  },
  "devDependencies": {
    "@open-wc/testing": "^3.2.0",
    "@web/test-runner": "^0.18.0",
    "@web/test-runner-commands": "^0.9.0",
    "@web/test-runner-playwright": "^0.11.0",
    "@rollup/plugin-terser": "^1.0.0",
    "rollup": "^4.0.0"
  }
}